# -----------------------------------------------------------
# PYTHON / FASTAPI
# -----------------------------------------------------------
# Виртуальное окружение
venv/
.venv/
env/
ENV/

# Байт-код и кэш
__pycache__/
*.py[cod]
*$py.class
*.so

# Дистрибутивы и пакеты
build/
dist/
*.egg-info/
*.egg

# Alembic (миграции коммитим, но игнорируем лишнее)
# Важно: папку alembic/versions НЕ игнорируем, там код миграций!
alembic.ini
# Если используешь sqlite локально
*.db
*.sqlite
*.sqlite3

# Переменные окружения (секреты, ключи, доступы к БД)
data/
.env
.env.local
.env.*.local
backend/migrations/env.py

# Логирование
*.log
logs/

# Тесты и покрытие
.pytest_cache/
.coverage
htmlcov/
.tox/

# -----------------------------------------------------------
# IDE / РЕДАКТОРЫ
# -----------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------
# FRONTEND (HTML / CSS / JS)
# -----------------------------------------------------------
# На случай, если фронтенд решит использовать сборщики (npm/yarn)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Сборки (если вдруг появятся)
dist/
build/

# -----------------------------------------------------------
# ОПЕРАЦИОННЫЕ СИСТЕМЫ
# -----------------------------------------------------------
